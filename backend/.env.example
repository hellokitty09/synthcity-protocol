# ═══════════════════════════════════════════════
#  SYNTHCITY BACKEND — Environment Variables
# ═══════════════════════════════════════════════

# ── Server ──────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Blockchain RPC ──────────────────────────────
# Local Anvil: http://127.0.0.1:8545
# Base Sepolia: https://sepolia.base.org
# Alchemy:      https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC=http://127.0.0.1:8545

# ── Contract Addresses ──────────────────────────
# Set these after running: forge script script/DeploySynthCity.s.sol
# The deploy script prints these values at the end.
# Defaults below are Anvil local deployment addresses.

# Core (always required)
SYNTH_TOKEN_ADDR=0x5fbdb2315678afecb367f032d93f642f64180aa3
LAND_REGISTRY_ADDR=0xe7f1725e7734ce288f8367e1bb143e90bb3f0512

# Extended (optional — backend gracefully degrades without these)
AGENT_REGISTRY_ADDR=
STAKING_MANAGER_ADDR=
DOMAIN_MANAGER_ADDR=
TRADE_BLOCS_ADDR=
VAULT_ADDRESS=

# ── Wallet Keys (CRITICAL — keep secret) ────────
# Treasury wallet that can mint $SYNTH rewards.
# Default is Anvil account[0] — NEVER use in production.
TREASURY_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Agent Private Keys ──────────────────────────
# Each sovereign agent needs its own wallet.
# Defaults are Anvil test accounts — generate fresh keys for production.
AGENT_1_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
AGENT_1_FACTION=Neon Syndicate
AGENT_1_STYLE=macro

AGENT_2_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
AGENT_2_FACTION=Obsidian Core
AGENT_2_STYLE=geopolitical

# ── Timing (ms) ─────────────────────────────────
CYCLE_INTERVAL_MS=90000
PRICE_POLL_MS=30000
INTEL_POLL_MS=60000
LAND_POLL_MS=5000
GRID_SIZE=25

# ── CORS (comma-separated origins) ─────────────
CORS_ORIGINS=http://localhost:3000

# ── Auth & Security ─────────────────────────────
# Admin API key for system operations (settle cycles).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=
SESSION_DURATION_HOURS=72

# ── Database ────────────────────────────────────
# SQLite DB path (auto-created on first boot).
DB_PATH=./synthcity.db

# ── SSE ─────────────────────────────────────────
MAX_SSE_CLIENTS=100

# ── Ollama LLM (optional) ──────────────────────
# Falls back to rule-based intelligence if unavailable.
OLLAMA_URL=http://127.0.0.1:11434
